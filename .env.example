# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Alpha Vantage (free tier: 25 req/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# NewsAPI (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# FRED (US macro data)
FRED_API_KEY=your_fred_api_key_here

# Model overrides (optional — defaults live in config/settings.py)
# Verify exact IDs against your provider dashboards; a wrong string fails at
# runtime (Claude/GPT track will log an error and skip that call).
# CLAUDE_DECISION_MODEL=claude-sonnet-5
# CLAUDE_ERL_MODEL=claude-opus-4-8
# CLAUDE_ERL_EXTENDED_THINKING=true
# CLAUDE_PROMPT_MODEL=claude-opus-4-8     # MIPRO instruction proposer (Claude track)
# GPT_DECISION_MODEL=gpt-5
# GPT_NEWS_MODEL=gpt-5-mini               # shared news analysis (both tracks)
# GPT_ERL_MODEL=gpt-5.5
# GPT_ERL_REASONING_EFFORT=high           # high|medium|low|minimal; empty disables
# GPT_PROMPT_MODEL=gpt-5.5                 # MIPRO instruction proposer (GPT track)

# App settings
LOG_LEVEL=INFO
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
RESET_PIN=3821

# MIPRO artifact backup (optional but recommended)
# Local git working copy of a standalone backups repo. After each MIPRO run the
# new compiled program is copied here (full timestamped history + latest.json),
# committed, and pushed. The working copy's remote must have push credentials.
# Empty = backup disabled. One-time setup on the Pi:
#   git clone git@github.com:<you>/deepswing-mipro-backups.git ~/Github/deepswing-mipro-backups
MIPRO_BACKUP_REPO_DIR=
MIPRO_BACKUP_PUSH=true
